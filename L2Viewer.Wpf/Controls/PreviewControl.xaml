<UserControl x:Class="L2Viewer.Wpf.Controls.PreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:hx="clr-namespace:HelixToolkit.Wpf.SharpDX;assembly=HelixToolkit.Wpf.SharpDX"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid MinHeight="220">
        <Border x:Name="EmptyPreviewBorder"
                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1">
            <Viewbox>
                <TextBlock Text="No preview"
                           FontWeight="SemiBold" />
            </Viewbox>
        </Border>

        <Border x:Name="TexturePreviewBorder"
                Visibility="Collapsed"
                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Image x:Name="TextureImage"
                       Stretch="None"
                       SnapsToDevicePixels="True"
                       UseLayoutRounding="True" />
            </ScrollViewer>
        </Border>

        <Border x:Name="MeshPreviewBorder"
                Visibility="Collapsed"
                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1"
                ClipToBounds="True">
            <hx:Viewport3DX x:Name="Viewport"
                            BackgroundColor="WhiteSmoke"
                            EffectsManager="{Binding EffectsManager}"
                            CameraRotationMode="Turnball"
                            ShowViewCube="False"
                            IsPanEnabled="True"
                            IsZoomEnabled="True"
                            IsRotationEnabled="True"
                            IsMoveEnabled="True"
                            ShowCoordinateSystem="True"
                            ShowFrameRate="True"
                            ZoomExtentsWhenLoaded="False"
                            Focusable="True">
                <hx:Viewport3DX.InputBindings>
                    <KeyBinding Key="D" Command="NotACommand" />
                </hx:Viewport3DX.InputBindings>
                <hx:Viewport3DX.Camera>
                    <hx:PerspectiveCamera x:Name="Camera"
                                          Position="0,0,220"
                                          LookDirection="0,0,-220"
                                          UpDirection="0,1,0"
                                          FarPlaneDistance="100000" />
                </hx:Viewport3DX.Camera>
                <hx:AmbientLight3D x:Name="AmbientLight" Color="#AAAAAA" />
                <hx:ShadowMap3D x:Name="ShadowMap" Resolution="2048,2048" />
                <hx:DirectionalLight3D x:Name="PreviewKeyLight"
                                       Color="#FFF4D8"
                                       Direction="-0.55,-0.75,-0.35" />
                <hx:DirectionalLight3D x:Name="PreviewFillLight"
                                       Color="#C9DBFF"
                                       Direction="0.35,0.45,0.80" />
                <hx:GroupModel3D x:Name="MapSunLightsGroup" />
                <hx:GroupModel3D x:Name="MapMoonLightsGroup" />
                <hx:GroupModel3D x:Name="MapLightsGroup" />
                <hx:GroupModel3D x:Name="SceneRoot">
                    <hx:MeshGeometryModel3D x:Name="MeshModel" Visibility="Visible"
                                            CullMode="Back" />
                    <hx:MeshGeometryModel3D x:Name="CollisionMeshModel" Visibility="Collapsed"
                                            CullMode="Back" />
                    <hx:GroupModel3D x:Name="WaterSceneGroup" Visibility="Visible" />
                    <hx:GroupModel3D x:Name="VolumeSceneGroup" Visibility="Collapsed" />
                    <hx:GroupModel3D x:Name="PropSceneGroup" />
                    <hx:GroupModel3D x:Name="PolySceneGroup" />
                    <hx:LineGeometryModel3D x:Name="BoundsModel"
                                            Thickness="1.2"
                                            Color="#FFB347" />
                    <hx:LineGeometryModel3D x:Name="BoneOverlayModel"
                                            Thickness="2.4"
                                            Color="#4DFF93"
                                            DepthBias="-64"
                                            SlopeScaledDepthBias="-2" />
                    <hx:PointGeometryModel3D x:Name="VertexDebugModel"
                                             Figure="Cross"
                                             Size="5,5"
                                             Color="#FF3355" />
                </hx:GroupModel3D>
            </hx:Viewport3DX>
        </Border>
    </Grid>
</UserControl>
