<UserControl x:Class="L2Viewer.Wpf.Controls.PackageInfoControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <TabControl x:Name="InfoTabControl" x:FieldModifier="public">
        <TabItem Header="Map Info">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="12">
                    <TextBlock Text="Map" FontWeight="SemiBold" />
                    <TextBlock x:Name="MapNameTextBlock" x:FieldModifier="public" Margin="0,4,0,0" FontFamily="Consolas" />
                    <TextBlock x:Name="MapVersionTextBlock" x:FieldModifier="public" Margin="0,2,0,0" FontFamily="Consolas" />

                    <TextBlock Margin="0,0,0,8" Text="Terrain Layers" FontWeight="SemiBold" />
                    <TextBlock x:Name="TerrainStatusTextBlock" x:FieldModifier="public" Margin="0,4,0,0" FontFamily="Consolas" />

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="8" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Height Map" FontWeight="SemiBold" />
                                <TextBlock x:Name="HeightMapRefTextBlock" x:FieldModifier="public" Margin="0,6,0,0" FontFamily="Consolas" TextWrapping="Wrap" />
                                <TextBlock x:Name="HeightMapSizeTextBlock" x:FieldModifier="public" Margin="0,2,0,8" FontFamily="Consolas" />
                                <Border Height="120" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1">
                                    <Image x:Name="HeightMapPreviewImage" x:FieldModifier="public" Stretch="Uniform" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Padding="8" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Diffuse" FontWeight="SemiBold" />
                                <TextBlock x:Name="DiffuseTextureRefTextBlock" x:FieldModifier="public" Margin="0,6,0,0" FontFamily="Consolas" TextWrapping="Wrap" />
                                <TextBlock x:Name="DiffuseTextureSizeTextBlock" x:FieldModifier="public" Margin="0,2,0,8" FontFamily="Consolas" />
                                <Border Height="120" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1">
                                    <Image x:Name="DiffuseTexturePreviewImage" x:FieldModifier="public" Stretch="Uniform" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Padding="8" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Render Texture" FontWeight="SemiBold" />
                                <TextBlock x:Name="RenderTextureRefTextBlock" x:FieldModifier="public" Margin="0,6,0,0" FontFamily="Consolas" TextWrapping="Wrap" />
                                <TextBlock x:Name="RenderTextureSizeTextBlock" x:FieldModifier="public" Margin="0,2,0,8" FontFamily="Consolas" />
                                <Border Height="120" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1">
                                    <Image x:Name="RenderTexturePreviewImage" x:FieldModifier="public" Stretch="Uniform" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Margin="0,0,0,8" Text="Terrain Textures" FontWeight="SemiBold" />
                    <ItemsControl x:Name="TerrainTexturesItemsControl" x:FieldModifier="public" Margin="0,6,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="220" Margin="0,0,10,10" Padding="8" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                        <TextBlock Margin="0,4,0,0" FontFamily="Consolas" TextWrapping="Wrap" Text="{Binding Reference}" />
                                        <TextBlock Margin="0,2,0,8" FontFamily="Consolas" Text="{Binding Size}" />
                                        <Border Height="110" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1">
                                            <Image Stretch="Uniform" Source="{Binding Preview}" />
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="Technical">
            <TextBox x:Name="DetailsTextBox" x:FieldModifier="public" Padding="12" FontFamily="Consolas" FontSize="12"
                     IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
        </TabItem>
    </TabControl>
</UserControl>
