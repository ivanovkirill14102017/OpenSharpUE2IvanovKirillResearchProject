<Window x:Class="L2Viewer.BspDiagnostics.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hx="clr-namespace:HelixToolkit.Wpf.SharpDX;assembly=HelixToolkit.Wpf.SharpDX"
        mc:Ignorable="d"
        Title="L2 BSP Diagnostics"
        Width="1600"
        Height="940"
        MinWidth="1200"
        MinHeight="720">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="8"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left">
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="UNR" />
                    <TextBox x:Name="PathTextBox"
                             Width="360"
                             Padding="6,3" />
                    <Button x:Name="LoadButton"
                            Margin="8,0,0,0"
                            Padding="10,4"
                            Content="Load 20_20"
                            Click="LoadButton_Click" />
                    <Button x:Name="FitAllButton"
                            Margin="8,0,0,0"
                            Padding="10,4"
                            Content="Fit All"
                            Click="FitAllButton_Click" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,6,0"
                                   VerticalAlignment="Center"
                                   Text="Opacity" />
                        <Slider x:Name="OpacitySlider"
                                Width="120"
                                Minimum="0.05"
                                Maximum="1"
                                TickFrequency="0.05"
                                ValueChanged="OpacitySlider_ValueChanged" />
                        <TextBlock x:Name="OpacityValueTextBlock"
                                   Width="42"
                                   Margin="6,0,12,0"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right" />
                        <TextBlock Margin="0,0,6,0"
                                   VerticalAlignment="Center"
                                   Text="Speed" />
                        <Slider x:Name="SpeedSlider"
                                Width="120"
                                Minimum="0.2"
                                Maximum="5"
                                TickFrequency="0.1"
                                ValueChanged="SpeedSlider_ValueChanged" />
                        <TextBlock x:Name="SpeedValueTextBlock"
                                   Width="42"
                                   Margin="6,0,12,0"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right" />
                        <TextBlock Margin="0,0,6,0"
                                   VerticalAlignment="Center"
                                   Text="Saved Cameras" />
                        <ComboBox x:Name="CamerasComboBox"
                                  Width="180"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="CamerasComboBox_SelectionChanged" />
                        <Button x:Name="SaveCameraButton"
                                Margin="8,0,0,0"
                                Padding="10,4"
                                Content="Save Pos"
                                Click="SaveCameraButton_Click" />
                        <Button x:Name="CapturePointButton"
                                Margin="8,0,0,0"
                                Padding="10,4"
                                Content="Save Point"
                                Click="CapturePointButton_Click" />
                        <TextBox x:Name="CapturedPointTextBox"
                                 Width="240"
                                 Margin="8,0,0,0"
                                 Padding="6,3"
                                 IsReadOnly="True" />
                    </StackPanel>

                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="PolyFlags" />
                        <ItemsControl ItemsSource="{Binding PolyFlagFilters}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Margin="0,0,12,0"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsHidden, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBlock Text="{Binding Name}" />
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" MinWidth="280" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12"
                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock x:Name="SceneTitleTextBlock"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="No scene loaded" />
                        <TextBlock x:Name="SceneSummaryTextBlock"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="SelectionSummaryTextBlock"
                                   Margin="0,10,0,10"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ListBox x:Name="ModelsListBox"
                             ItemsSource="{Binding ModelEntries}"
                             SelectionChanged="ModelsListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Left"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Top"
                                                  IsChecked="{Binding IsVisible, UpdateSourceTrigger=PropertyChanged}" />
                                        <StackPanel Margin="{Binding IndentMargin}">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Title}" />
                                            <TextBlock FontSize="11"
                                                       Opacity="0.8"
                                                       Text="{Binding Summary}" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True" />

            <Border Grid.Column="2"
                    Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1"
                    ClipToBounds="True">
                <hx:Viewport3DX x:Name="Viewport"
                                BackgroundColor="WhiteSmoke"
                                CameraMode="WalkAround"
                                CameraRotationMode="Turntable"
                                ShowCoordinateSystem="True"
                                ShowFrameRate="True"
                                ShowViewCube="False"
                                IsPanEnabled="True"
                                IsZoomEnabled="True"
                                IsRotationEnabled="True"
                                IsMoveEnabled="True"
                                ZoomExtentsWhenLoaded="False"
                                EffectsManager="{Binding EffectsManager}"
                                Focusable="True"
                                MouseDown="Viewport_MouseDown">
                    <hx:Viewport3DX.InputBindings>
                        <KeyBinding Key="D" Command="NotACommand" />
                    </hx:Viewport3DX.InputBindings>
                    <hx:Viewport3DX.Camera>
                        <hx:PerspectiveCamera x:Name="Camera"
                                              Position="0,0,220"
                                              LookDirection="0,0,-220"
                                              UpDirection="0,1,0"
                                              FarPlaneDistance="100000" />
                    </hx:Viewport3DX.Camera>
                    <hx:AmbientLight3D Color="#BBBBBB" />
                    <hx:DirectionalLight3D Direction="-0.4,-1,-0.3" Color="#FFFFFF" />
                    <hx:GroupModel3D x:Name="SceneRoot" />
                </hx:Viewport3DX>
            </Border>
        </Grid>
    </Grid>
</Window>
